#!/usr/bin/env bash
# Pre-commit hook: mirrors the CI Check & Lint job locally.
# Install once with: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}[pre-commit] Running fmt check...${NC}"
if ! cargo fmt --all -- --check 2>&1; then
    echo -e "${RED}[pre-commit] Formatting errors found. Run 'cargo fmt --all' to fix.${NC}"
    exit 1
fi
echo -e "${GREEN}[pre-commit] fmt OK${NC}"

echo -e "${YELLOW}[pre-commit] Running clippy...${NC}"
if ! cargo clippy --all-targets --all-features -- -D warnings 2>&1; then
    echo -e "${RED}[pre-commit] Clippy errors found. Fix them before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}[pre-commit] clippy OK${NC}"

echo -e "${GREEN}[pre-commit] All checks passed.${NC}"
